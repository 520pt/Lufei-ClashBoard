{
  "manifest_version": 3,
  "name": "LuFei 自定义规则助手",
  "description": "一键把当前网页域名或 IP 添加到 Lufei-ClashBoard 自定义代理或直连规则。",
  "version": "1.3.0",
  "icons": {
    "16": "icons/icon-192.png",
    "32": "icons/icon-192.png",
    "48": "icons/icon-192.png",
    "128": "icons/icon-192.png"
  },
  "action": {
    "default_title": "LuFei 自定义规则",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-192.png",
      "32": "icons/icon-192.png",
      "48": "icons/icon-192.png",
      "128": "icons/icon-192.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "contextMenus", "notifications", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
